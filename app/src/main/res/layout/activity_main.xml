<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout principal — barre de navigation style One UI :
    - Texte seul (icônes masquées : app:itemIconSize="0dp")
    - Indicateur actif réduit à une ligne fine (#itemActiveIndicatorHeight)
    - Hauteur compacte (56dp, comme One UI sans icônes)
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="56dp"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph"/>

    <!--
        BottomNavigationView configuré pour imiter les onglets texte de One UI :
        - itemIconSize = 0dp    → icônes masquées, texte seul visible
        - labelVisibilityMode  → always labeled
        - itemActiveIndicatorHeight = 3dp → fine ligne sous l'onglet actif
        - itemActiveIndicatorWidth  = 48dp → largeur de la ligne
    -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:background="?attr/colorSurface"
        app:elevation="0dp"
        app:itemIconSize="0dp"
        app:labelVisibilityMode="labeled"
        app:itemTextColor="@color/bottom_nav_item"
        app:itemActiveIndicatorHeight="3dp"
        app:itemActiveIndicatorWidth="48dp"
        app:itemActiveIndicatorStyle="@style/Widget.App.BottomNav.ActiveIndicator"
        app:menu="@menu/bottom_nav"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
