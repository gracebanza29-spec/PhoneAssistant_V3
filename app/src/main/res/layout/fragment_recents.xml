<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
    <com.google.android.material.appbar.MaterialToolbar android:layout_width="match_parent" android:layout_height="?attr/actionBarSize" app:title="Recents"/>
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:scrollbars="none">
        <com.google.android.material.chip.ChipGroup android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="8dp" app:singleSelection="true">
            <com.google.android.material.chip.Chip android:id="@+id/chip_all" style="@style/Widget.Material3.Chip.Filter" android:text="Tous" android:checked="true"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_missed" style="@style/Widget.Material3.Chip.Filter" android:text="Manques"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_in" style="@style/Widget.Material3.Chip.Filter" android:text="Recus"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_out" style="@style/Widget.Material3.Chip.Filter" android:text="Emis"/>
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>
    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv" android:layout_width="match_parent" android:layout_height="match_parent" android:paddingBottom="72dp" android:clipToPadding="false"/>
        <ProgressBar android:id="@+id/progress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone"/>
        <TextView android:id="@+id/tv_empty" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Aucun appel recent" android:visibility="gone"/>
    </FrameLayout>
</LinearLayout>
